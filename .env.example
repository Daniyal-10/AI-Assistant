# ================================
# NEXUS Environment Configuration
# ================================
# This is a TEMPLATE file.
# Copy this to `.env` and fill actual values.
# DO NOT put secrets here.

# ----------------
# Ollama (Local AI)
# ----------------
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CODE_MODEL=qwen2.5-coder:7b
OLLAMA_REASON_MODEL=llama3.1:8b
OLLAMA_TIMEOUT=120

# ----------------
# Execution Engine
# ----------------
EXEC_TIMEOUT=30
MAX_FIX_ITERATIONS=3
WORKSPACE_BASE=/tmp/nexus

# ----------------
# Telegram (Optional - Phase 1 not required)
# ----------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
ALLOWED_TELEGRAM_USERS=your_user_id_here

# ----------------
# Anthropic (Optional Fallback)
# ----------------
ANTHROPIC_API_KEY=your_key_here
FALLBACK_ENABLED=true
FALLBACK_MODEL=claude-haiku-4-5-20251001
